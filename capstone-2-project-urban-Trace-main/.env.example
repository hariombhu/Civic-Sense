# ─── Email Configuration (Gmail) ───────────
# For development: Leave empty to use console backend
# For production: Add real credentials

# Leave empty for console output (development)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Gmail SMTP (production)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=UrbanTrace Alerts <your-email@gmail.com>
REPORT_RECIPIENT_EMAIL=admin@example.com

# ─── CORS Settings ────────────────────────
CORS_ALLOW_ALL_ORIGINS=True

# ─── Frontend URL ────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── JWT Settings ────────────────────────
# Token lifetime in hours
JWT_ACCESS_TOKEN_LIFETIME=24
JWT_REFRESH_TOKEN_LIFETIME=7

